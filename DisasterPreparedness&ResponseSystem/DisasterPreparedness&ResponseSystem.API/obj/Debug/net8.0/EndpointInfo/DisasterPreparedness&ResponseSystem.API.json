        "properties": {
          "type": {
            "$ref": "#/components/schemas/DisasterType"
          },
          "severity": {
            "$ref": "#/components/schemas/SeverityLevel"
          },
          "latitude": {
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "type": "number",
            "format": "double"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "locationName": {
            "type": "string",
            "nullable": true
          },
          "affectedAreaRadiusKm": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          }
