  "info": {
    "title": "Pakistan Disaster Response System API",
    "description": "Real-time disaster preparedness and response system for Pakistan.\r\n\r\n**Roles:**\r\n- 🔓 Public — no login required\r\n- 👤 Citizen — submit reports, view disasters\r\n- 🚒 Responder — update assignment status (Rescue 1122, Edhi, PDMA etc.)\r\n- 👑 Admin — verify disasters, manage organizations, override assignments\r\n\r\n**Flow:** Citizen Report → Admin Verify → Auto-Assign Responder → Real-time Alert",
    "contact": {
      "name": "NDMA Pakistan",
      "email": "webadmin@ndma.gov.pk"
    },
    "version": "v1"
  },
