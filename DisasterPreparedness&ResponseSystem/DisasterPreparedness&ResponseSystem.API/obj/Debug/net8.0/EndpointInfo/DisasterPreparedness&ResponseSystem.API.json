  "components": {
    "schemas": {
      "AssignmentStatus": {
        "enum": [
          "Assigned",
          "EnRoute",
          "OnSite",
          "Completed",
          "Cancelled"
        ],
        "type": "string"
      },
      "ChatRequest": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "array",
            "items": { },
            "nullable": true
          },
          "userMessage": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CompleteAssignmentDto": {
        "type": "object",
        "properties": {
          "completionNotes": {
            "type": "string",
            "nullable": true
          },
          "completionPhotoBase64": {
            "type": "string",
            "nullable": true
