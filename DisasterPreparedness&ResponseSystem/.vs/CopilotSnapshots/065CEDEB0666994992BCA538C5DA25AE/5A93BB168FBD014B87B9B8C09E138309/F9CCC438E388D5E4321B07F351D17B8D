
using DisasterPreparedness_ResponseSystem.Core.DTOs;
using DisasterPreparedness_ResponseSystem.Core.Entity;
using DisasterPreparedness_ResponseSystem.Core.Helpers;
using DisasterPreparedness_ResponseSystem.Core.Interfaces;
using DisasterPreparedness_ResponseSystem.Hubs;
using DisasterPreparedness_ResponseSystem.Infrastructure.Data;
using Microsoft.AspNetCore.SignalR;
using Microsoft.EntityFrameworkCore;
using static DisasterPreparedness_ResponseSystem.Core.Entity.Enums;

namespace DisasterPreparedness_ResponseSystem.Infrastructure.Services
{
    public class AlertService : IAlertService
    {
        private readonly IHubContext<DisasterHub, IDisasterHubClient> _hubContext;
        private readonly AppDbContext _db;
        private readonly IPushNotificationService _push;

        public AlertService(
            IHubContext<DisasterHub, IDisasterHubClient> hubContext,
            AppDbContext db, IPushNotificationService push)
        {
            _hubContext = hubContext;
            _db = db;
            _push = push;
        }

        public async Task SendDisasterAlertAsync(Disaster disaster)
        {
            var assignment = await _db.ResponderAssignments
                .Include(a => a.ResponderOrganization)
                .FirstOrDefaultAsync(a => a.DisasterId == disaster.Id);

            var alertRecord = new Alert
            {
                DisasterId = disaster.Id,
                Message = $"{disaster.Type} alert: {disaster.Description}",
                Severity = disaster.Severity,
                Audience = AlertAudience.AllUsers,
                CreatedAt = DateTime.UtcNow
            };
            _db.Alerts.Add(alertRecord);
            await _db.SaveChangesAsync();   

            var alert = new RealTimeAlertDto
            {
                DisasterId = disaster.Id,
                DisasterType = disaster.Type.ToString(),
                Severity = disaster.Severity.ToString(),
                Status = disaster.Status.ToString(),
                Source = disaster.Source.ToString(),
                Latitude = disaster.Latitude,
                Longitude = disaster.Longitude,
                Description = disaster.Description,
                AffectedCity = GetNearestCity(disaster.Latitude, disaster.Longitude),
                CreatedAt = disaster.ReportedAt,
                AssignedOrganization = assignment?.ResponderOrganization?.Name,
                AssignedOrgContact = assignment?.ResponderOrganization?.ContactNumber
            };

            await _hubContext.Clients.Group("PublicFeed").ReceiveDisasterAlert(alert);

            var cityGroup = $"City_{alert.AffectedCity.Replace(" ", "_")}";
            await _hubContext.Clients.Group(cityGroup).ReceiveDisasterAlert(alert);

            if (disaster.Severity is SeverityLevel.Critical or SeverityLevel.High)
                await _hubContext.Clients.Group("Admins").ReceiveDisasterAlert(alert);

            await _push.SendToRoleAsync("Citizen",
    $"🚨 {disaster.Type} Alert — {GetNearestCity(disaster.Latitude, disaster.Longitude)}",
    disaster.Description?.Length > 80
        ? disaster.Description[..80] + "..."
        : disaster.Description ?? "",
    $"/disasters/{disaster.Id}");
        }

        public async Task SendAssignmentUpdateAsync(ResponderAssignment assignment)
        {
            var org = await _db.ResponderOrganizations.FindAsync(assignment.ResponderOrganizationId);

            var update = new AssignmentUpdateDto
            {
                AssignmentId = assignment.Id,
                DisasterId = assignment.DisasterId,
                OrganizationName = org?.Name ?? "Unknown",
                Status = assignment.Status.ToString(),
                Method = assignment.Method.ToString(),
                UpdatedAt = DateTime.UtcNow
            };

            await _hubContext.Clients.Group("Admins").ReceiveAssignmentUpdate(update);
            await _hubContext.Clients.Group("Responders").ReceiveAssignmentUpdate(update);
        }

        public async Task SendNewReportNotificationAsync(DisasterReport report, string reporterName)
        {
            var notification = new NewReportNotificationDto
            {
                ReportId = report.Id,
                ReportedBy = reporterName,
                Description = report.Description,
                Latitude = report.Latitude,
                Longitude = report.Longitude,
                CreatedAt = report.CreatedAt
            };

            await _hubContext.Clients.Group("Admins").ReceiveNewReport(notification);

            await _push.SendToRoleAsync("Admin",
                $"📩 New Report from {reporterName}",
                report.Description?.Length > 80
                    ? report.Description[..80] + "..."
                    : report.Description ?? "",
                "/admin");
        }
        private static string GetNearestCity(double lat, double lon)
        {
            var cities = new Dictionary<string, (double Lat, double Lon)>
        {
            { "Lahore",     (31.5204, 74.3587) },
            { "Karachi",    (24.8607, 67.0011) },
            { "Islamabad",  (33.6844, 73.0479) },
            { "Peshawar",   (34.0151, 71.5249) },
            { "Quetta",     (30.1798, 66.9750) },
            { "Multan",     (30.1575, 71.5249) },
            { "Faisalabad", (31.4504, 73.1350) },
            { "Rawalpindi", (33.5651, 73.0169) }
        };

            return cities
                .OrderBy(c => DistanceCalculator.CalculateKm(lat, lon, c.Value.Lat, c.Value.Lon))
                .First()
                .Key;
        }

       
    }
}
