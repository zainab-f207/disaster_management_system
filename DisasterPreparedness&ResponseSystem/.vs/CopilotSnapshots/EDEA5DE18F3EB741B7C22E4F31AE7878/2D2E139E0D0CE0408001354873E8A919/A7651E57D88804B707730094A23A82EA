using DisasterPreparedness_ResponseSystem.Core.DTOs;
using DisasterPreparedness_ResponseSystem.Core.Entity;
using DisasterPreparedness_ResponseSystem.Core.Helpers;
using DisasterPreparedness_ResponseSystem.Core.Interfaces;
using DisasterPreparedness_ResponseSystem.Infrastructure.Data;
using DisasterPreparedness_ResponseSystem.Infrastructure.Interfaces;
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.Logging;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using static DisasterPreparedness_ResponseSystem.Core.Entity.Enums;

namespace DisasterPreparedness_ResponseSystem.Infrastructure.Services
{
    public class DisasterCreationService : IDisasterCreationService
    {
        private readonly AppDbContext _db;
        private readonly IResponderAssignmentService _assignment;
        private readonly IAlertService _alert;
        private readonly IPushNotificationService _push;
        private readonly ILogger<DisasterCreationService> _logger;

        public DisasterCreationService(
            AppDbContext db,
            IResponderAssignmentService assignment,
            IAlertService alert,
            IPushNotificationService push,
            ILogger<DisasterCreationService> logger)
        {
            _db = db;
            _assignment = assignment;
            _alert = alert;
            _push = push;
            _logger = logger;
        }

        public async Task<DisasterReport> CreateCitizenReportAsync(
            string userId, CreateReportDto dto)
        {
            var nearby = await FindNearbyActiveDisasterAsync(dto.Type, dto.Latitude, dto.Longitude, 5);

            var report = new DisasterReport
            {
                ReportedByUserId = userId,
                Type = dto.Type,
                Description = dto.Description,
                Latitude = dto.Latitude,
                Longitude = dto.Longitude,
                LocationName = dto.LocationName ?? string.Empty,
                ImageUrl = dto.ImageBase64 ?? dto.ImageUrl,
                Status = ReportStatus.Pending,
                DisasterId = nearby?.Id,
                IsDuplicate = nearby != null
            };

            _db.DisasterReports.Add(report);
            await _db.SaveChangesAsync();

            await _alert.SendNewReportNotificationAsync(report,
                (await _db.Users.FindAsync(userId))?.FullName ?? "Citizen");

            await SafePushAsync("Admin",
                $"📩 New {dto.Type} Report",
                dto.Description?.Length > 60 ? dto.Description[..60] + "..." : dto.Description ?? "",
                "/admin");

            return report;
        }

        public async Task<DisasterReport?> GetReportByIdAsync(int reportId)
        {
            return await _db.DisasterReports.FindAsync(reportId);
        }

        public async Task<Disaster> CreateAdminDisasterAsync(
            string adminId, CreateAdminDisasterDto dto)
        {
            var isAlertOnly = DisasterCategoryHelper.IsAlertOnly(dto.Type);

            var disaster = new Disaster
            {
                Type = dto.Type,
                Severity = dto.Severity,
                Latitude = dto.Latitude,
                Longitude = dto.Longitude,
                AffectedAreaRadiusKm = dto.AffectedAreaRadiusKm,
                Description = dto.Description,
                Source = DisasterSource.AdminReport,
                Status = isAlertOnly ? DisasterStatus.AlertActive : DisasterStatus.Verified,
                VerifiedAt = DateTime.UtcNow,
                VerifiedByUserId = adminId,
                ReportedAt = DateTime.UtcNow,
            };

            _db.Disasters.Add(disaster);
            await _db.SaveChangesAsync();

            await _alert.SendDisasterAlertAsync(disaster);

            if (!isAlertOnly)
            {
                try { await _assignment.AutoAssignAsync(disaster.Id); }
                catch (Exception ex)
                {
                    _logger.LogWarning("Auto-assign failed for admin disaster {Id}: {Msg}",
                        disaster.Id, ex.Message);
                }
            }

            await SafePushAsync("Citizen",
                $"🚨 {dto.Type} Alert — {(dto.Description?.Length > 50 ? dto.Description[..50] + "..." : dto.Description)}",
                DisasterCategoryHelper.IsAlertOnly(dto.Type)
                    ? DisasterCategoryHelper.GetPrecautionMessage(dto.Type)
                    : "Rescue teams have been dispatched.",
                $"/disasters/{disaster.Id}");

            return disaster;
        }

        public async Task<Disaster?> CreateApiDisasterAsync(
            DisasterType type, SeverityLevel severity,
            double lat, double lon, string description,
            DisasterSource source)
        {
            if (!DisasterCategoryHelper.CanBeAutoDetected(type))
            {
                _logger.LogWarning("Blocked auto-creation of non-detectable type {Type}", type);
                return null;
            }

            var duplicate = await FindNearbyActiveDisasterAsync(type, lat, lon, 50);
            if (duplicate != null)
            {
                _logger.LogInformation("Skipping duplicate {Type} near {Lat},{Lon}", type, lat, lon);
                return null;
            }

            var isAlertOnly = DisasterCategoryHelper.IsAlertOnly(type);

            var disaster = new Disaster
            {
                Type = type,
                Severity = severity,
                Latitude = lat,
                Longitude = lon,
                Description = description,
                Source = source,
                Status = isAlertOnly ? DisasterStatus.AlertActive : DisasterStatus.Verified,
                VerifiedAt = DateTime.UtcNow,
                ReportedAt = DateTime.UtcNow,
            };

            _db.Disasters.Add(disaster);
            await _db.SaveChangesAsync();

            await _alert.SendDisasterAlertAsync(disaster);

            if (!isAlertOnly)
            {
                try { await _assignment.AutoAssignAsync(disaster.Id); }
                catch (Exception ex) { _logger.LogWarning("Auto-assign failed: {Msg}", ex.Message); }
            }

            await SafePushAsync("Citizen",
                isAlertOnly ? $"⚠️ {type} Alert" : $"🚨 {type} Emergency",
                isAlertOnly
                    ? DisasterCategoryHelper.GetPrecautionMessage(type)
                    : description?.Length > 80 ? description[..80] + "..." : description ?? "",
                $"/disasters/{disaster.Id}");

            return disaster;
        }

        public async Task<Disaster?> FindNearbyActiveDisasterAsync(
            DisasterType type, double lat, double lon, double radiusKm)
        {
            var active = await _db.Disasters
                .Where(d => d.Type == type &&
                           d.Status != DisasterStatus.Resolved &&
                           d.Status != DisasterStatus.FalseAlarm &&
                           d.Status != DisasterStatus.Closed &&
                           d.Status != DisasterStatus.AlertExpired)
                .ToListAsync();

            return active.FirstOrDefault(d =>
                DistanceCalculator.CalculateKm(lat, lon, d.Latitude, d.Longitude) <= radiusKm);
        }

        private async Task SafePushAsync(string role, string title, string body, string url)
        {
            try { await _push.SendToRoleAsync(role, title, body, url); }
            catch (Exception ex) { _logger.LogWarning("Push failed: {Msg}", ex.Message); }
        }
    }
}
